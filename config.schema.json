{
  "pluginAlias": "AcFreedom",
  "pluginType": "platform",
  "singular": false,
  "headerDisplay": "AUX Air Conditioner control via Broadlink (local) or AUX Cloud API.",
  "schema": {
    "type": "object",
    "properties": {
      "name": {
        "title": "Platform Name",
        "type": "string",
        "required": true,
        "default": "AC Freedom"
      },
      "devices": {
        "title": "Devices",
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": {
              "title": "Device Name",
              "type": "string",
              "required": true,
              "default": "AC Freedom"
            },
            "connection": {
              "title": "Connection Mode",
              "type": "string",
              "required": true,
              "default": "cloud",
              "enum": ["cloud", "local"]
            },
            "cloudEmail": {
              "title": "Cloud Email",
              "type": "string",
              "condition": { "functionBody": "return model.devices[arrayIndices[0]].connection === 'cloud';" }
            },
            "cloudPassword": {
              "title": "Cloud Password",
              "type": "string",
              "condition": { "functionBody": "return model.devices[arrayIndices[0]].connection === 'cloud';" }
            },
            "cloudRegion": {
              "title": "Cloud Region",
              "type": "string",
              "default": "eu",
              "enum": ["eu", "usa", "cn", "rus"],
              "condition": { "functionBody": "return model.devices[arrayIndices[0]].connection === 'cloud';" }
            },
            "cloudDeviceId": {
              "title": "Cloud Device ID (leave empty for auto-detect)",
              "type": "string",
              "condition": { "functionBody": "return model.devices[arrayIndices[0]].connection === 'cloud';" }
            },
            "localIp": {
              "title": "IP Address",
              "type": "string",
              "format": "ipv4",
              "condition": { "functionBody": "return model.devices[arrayIndices[0]].connection === 'local';" }
            },
            "localMac": {
              "title": "MAC Address",
              "type": "string",
              "pattern": "^([A-Fa-f0-9]{2}:){5}[A-Fa-f0-9]{2}$",
              "placeholder": "AA:BB:CC:DD:EE:FF",
              "condition": { "functionBody": "return model.devices[arrayIndices[0]].connection === 'local';" }
            },
            "sleep": {
              "title": "Sleep Mode",
              "type": "boolean",
              "default": true
            },
            "health": {
              "title": "Health / Ionizer",
              "type": "boolean",
              "default": true
            },
            "eco": {
              "title": "Eco / Mildew Prevention",
              "type": "boolean",
              "default": true
            },
            "clean": {
              "title": "Self Clean",
              "type": "boolean",
              "default": true
            },
            "comfwind": {
              "title": "Comfortable Wind",
              "type": "boolean",
              "default": true
            },
            "display": {
              "title": "Display",
              "type": "boolean",
              "default": true
            },
            "pollInterval": {
              "title": "Poll Interval (seconds)",
              "type": "integer",
              "default": 30,
              "minimum": 5,
              "maximum": 300
            },
            "tempStep": {
              "title": "Temperature Step",
              "type": "number",
              "default": 0.5,
              "minimum": 0.5,
              "maximum": 1
            }
          }
        }
      }
    }
  },
  "form": null,
  "display": null
}
