{
  "pluginAlias": "AcFreedom",
  "pluginType": "platform",
  "singular": true,
  "customUi": true,
  "headerDisplay": "AUX Air Conditioner control via Broadlink (local) or AUX Cloud API.",
  "schema": {
    "type": "object",
    "required": ["name"],
    "properties": {
      "name": {
        "title": "Platform Name",
        "type": "string",
        "default": "AC Freedom"
      },
      "cloud": {
        "title": "Cloud Credentials",
        "type": "object",
        "properties": {
          "email": {
            "title": "Email",
            "type": "string"
          },
          "password": {
            "title": "Password",
            "type": "string"
          },
          "region": {
            "title": "Region",
            "type": "string",
            "default": "eu",
            "enum": ["eu", "usa", "cn", "rus"]
          }
        }
      },
      "devices": {
        "title": "Devices",
        "type": "array",
        "items": {
          "type": "object",
          "required": ["name", "connection"],
          "properties": {
            "name": {
              "title": "Device Name",
              "type": "string",
              "default": "AC Freedom"
            },
            "connection": {
              "title": "Connection Mode",
              "type": "string",
              "default": "hybrid",
              "enum": ["hybrid", "local", "cloud"]
            },
            "endpointId": {
              "title": "Device ID (endpointId, leave empty for auto-detect)",
              "type": "string"
            },
            "local": {
              "type": "object",
              "properties": {
                "ip": {
                  "title": "IP Address",
                  "type": "string"
                },
                "mac": {
                  "title": "MAC Address (AA:BB:CC:DD:EE:FF)",
                  "type": "string"
                }
              }
            },
            "presets": {
              "type": "object",
              "properties": {
                "sleep":  { "title": "Sleep Mode",              "type": "boolean", "default": true },
                "health": { "title": "Health / Ionizer",        "type": "boolean", "default": true },
                "eco":    { "title": "Eco / Mildew Prevention", "type": "boolean", "default": true },
                "clean":  { "title": "Self Clean",              "type": "boolean", "default": true }
              }
            },
            "showFan": {
              "title": "Fan",
              "type": "boolean",
              "default": true
            },
            "showComfWind": {
              "title": "Comfortable Wind",
              "type": "boolean",
              "default": true
            },
            "showDisplay": {
              "title": "Display",
              "type": "boolean",
              "default": true
            },
            "pollInterval": {
              "title": "Poll Interval (seconds)",
              "type": "integer",
              "default": 30,
              "minimum": 5,
              "maximum": 300
            },
            "tempStep": {
              "title": "Temperature Step",
              "type": "number",
              "default": 0.5,
              "enum": [0.5, 1]
            }
          }
        }
      }
    }
  },
  "layout": [
    { "key": "name" },
    {
      "key": "cloud",
      "type": "fieldset",
      "title": "Cloud Credentials (for Hybrid mode)",
      "items": [
        { "key": "cloud.email" },
        { "key": "cloud.password" },
        {
          "key": "cloud.region",
          "titleMap": {
            "eu":  "Europe",
            "usa": "USA",
            "cn":  "China",
            "rus": "Russia"
          }
        }
      ]
    },
    {
      "key": "devices",
      "type": "array",
      "buttonText": "Add Device",
      "items": [
        {
          "type": "section",
          "expandable": true,
          "expanded": false,
          "title": "{{ value.name || 'New Device' }}",
          "items": [
            { "key": "devices[].name" },
            {
              "key": "devices[].connection",
              "titleMap": {
                "hybrid": "Hybrid (Cloud + optional Local)",
                "local":  "Local Only (Broadlink UDP)"
              }
            },
            { "key": "devices[].endpointId" },
            {
              "key": "devices[].local",
              "type": "fieldset",
              "title": "Local Settings",
              "items": [
                { "key": "devices[].local.ip" },
                { "key": "devices[].local.mac" }
              ]
            },
            { "key": "devices[].showFan" },
            {
              "key": "devices[].presets",
              "type": "fieldset",
              "title": "Features",
              "items": [
                { "key": "devices[].presets.sleep" },
                { "key": "devices[].presets.health" },
                { "key": "devices[].presets.eco" },
                { "key": "devices[].presets.clean" },
                { "key": "devices[].showComfWind" },
                { "key": "devices[].showDisplay" }
              ]
            },
            {
              "key": "devices[].tempStep",
              "titleMap": {
                "0.5": "0.5 °C",
                "1":   "1 °C"
              }
            },
            { "key": "devices[].pollInterval" }
          ]
        }
      ]
    }
  ]
}
