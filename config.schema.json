{
  "pluginAlias": "AcFreedom",
  "pluginType": "platform",
  "singular": false,
  "headerDisplay": "AUX Air Conditioner control via Broadlink (local) or AUX Cloud API.",
  "schema": {
    "type": "object",
    "required": ["name"],
    "properties": {
      "name": {
        "title": "Platform Name",
        "type": "string",
        "default": "AC Freedom"
      },
      "devices": {
        "title": "Devices",
        "type": "array",
        "items": {
          "type": "object",
          "required": ["name", "connection"],
          "properties": {
            "name": {
              "title": "Device Name",
              "type": "string",
              "default": "AC Freedom"
            },
            "connection": {
              "title": "Connection Mode",
              "type": "string",
              "default": "cloud",
              "enum": ["cloud", "local"]
            },
            "cloud": {
              "type": "object",
              "properties": {
                "email": {
                  "title": "Email",
                  "type": "string"
                },
                "password": {
                  "title": "Password",
                  "type": "string"
                },
                "region": {
                  "title": "Region",
                  "type": "string",
                  "default": "eu",
                  "enum": ["eu", "usa", "cn", "rus"]
                },
                "deviceId": {
                  "title": "Device ID (endpointId, leave empty for auto-detect)",
                  "type": "string"
                }
              }
            },
            "local": {
              "type": "object",
              "properties": {
                "ip": {
                  "title": "IP Address",
                  "type": "string"
                },
                "mac": {
                  "title": "MAC Address (AA:BB:CC:DD:EE:FF)",
                  "type": "string"
                }
              }
            },
            "presets": {
              "type": "object",
              "properties": {
                "sleep": { "title": "Sleep", "type": "boolean", "default": true },
                "health": { "title": "Health", "type": "boolean", "default": true },
                "eco": { "title": "Eco", "type": "boolean", "default": true },
                "clean": { "title": "Self Clean", "type": "boolean", "default": true }
              }
            },
            "showComfWind": {
              "title": "Comf Wind",
              "type": "boolean",
              "default": true
            },
            "showDisplay": {
              "title": "Display",
              "type": "boolean",
              "default": true
            },
            "tempStep": {
              "title": "Temperature Step",
              "type": "number",
              "default": 0.5,
              "enum": [0.5, 1]
            }
          }
        }
      }
    }
  },
  "layout": [
    { "key": "name" },
    {
      "key": "devices",
      "type": "array",
      "buttonText": "Add Device",
      "items": [
        {
          "type": "section",
          "expandable": true,
          "expanded": false,
          "title": "{{ value.name || 'New Device' }}",
          "items": [
            { "key": "devices[].name" },
            {
              "key": "devices[].connection",
              "titleMap": {
                "cloud": "Cloud (AUX Cloud API)",
                "local": "Local (Broadlink UDP)"
              }
            },
            {
              "key": "devices[].cloud",
              "type": "fieldset",
              "title": "Cloud Settings",
              "condition": { "functionBody": "return model.devices[arrayIndices[0]].connection === 'cloud';" },
              "items": [
                { "key": "devices[].cloud.email" },
                { "key": "devices[].cloud.password" },
                {
                  "key": "devices[].cloud.region",
                  "titleMap": {
                    "eu": "Europe",
                    "usa": "USA",
                    "cn": "China",
                    "rus": "Russia"
                  }
                },
                { "key": "devices[].cloud.deviceId" }
              ]
            },
            {
              "key": "devices[].local",
              "type": "fieldset",
              "title": "Local Settings",
              "condition": { "functionBody": "return model.devices[arrayIndices[0]].connection === 'local';" },
              "items": [
                { "key": "devices[].local.ip" },
                { "key": "devices[].local.mac" }
              ]
            },
            {
              "type": "flex",
              "flex-flow": "row wrap",
              "items": [
                { "key": "devices[].presets.sleep", "flex": "1 1 33%" },
                { "key": "devices[].presets.health", "flex": "1 1 33%" },
                { "key": "devices[].presets.eco", "flex": "1 1 33%" },
                { "key": "devices[].presets.clean", "flex": "1 1 33%" },
                { "key": "devices[].showComfWind", "flex": "1 1 33%" },
                { "key": "devices[].showDisplay", "flex": "1 1 33%" }
              ]
            },
            {
              "key": "devices[].tempStep",
              "titleMap": {
                "0.5": "0.5 °C",
                "1": "1 °C"
              }
            }
          ]
        }
      ]
    }
  ]
}
