{
  "pluginAlias": "AcFreedom",
  "pluginType": "platform",
  "singular": false,
  "headerDisplay": "AUX Air Conditioner control via Broadlink (local) or AUX Cloud API.",
  "schema": {
    "type": "object",
    "required": ["name"],
    "properties": {
      "name": {
        "title": "Platform Name",
        "type": "string",
        "default": "AC Freedom"
      },
      "devices": {
        "title": "Devices",
        "type": "array",
        "items": {
          "type": "object",
          "required": ["name", "connection"],
          "properties": {
            "name": {
              "title": "Device Name",
              "type": "string",
              "default": "AC Freedom"
            },
            "connection": {
              "title": "Connection Mode",
              "type": "string",
              "default": "cloud",
              "oneOf": [
                { "title": "Cloud (AUX Cloud API)", "enum": ["cloud"] },
                { "title": "Local (Broadlink UDP)", "enum": ["local"] }
              ]
            },
            "cloud": {
              "title": "Cloud Settings",
              "type": "object",
              "required": ["email", "password"],
              "condition": { "functionBody": "return model.devices[arrayIndices[0]].connection === 'cloud';" },
              "properties": {
                "email": {
                  "title": "Email",
                  "type": "string"
                },
                "password": {
                  "title": "Password",
                  "type": "string"
                },
                "region": {
                  "title": "Region",
                  "type": "string",
                  "default": "eu",
                  "oneOf": [
                    { "title": "Europe", "enum": ["eu"] },
                    { "title": "USA", "enum": ["usa"] },
                    { "title": "China", "enum": ["cn"] },
                    { "title": "Russia", "enum": ["rus"] }
                  ]
                },
                "deviceId": {
                  "title": "Device ID (endpointId, leave empty for auto-detect)",
                  "type": "string"
                }
              }
            },
            "local": {
              "title": "Local Settings",
              "type": "object",
              "required": ["ip", "mac"],
              "condition": { "functionBody": "return model.devices[arrayIndices[0]].connection === 'local';" },
              "properties": {
                "ip": {
                  "title": "IP Address",
                  "type": "string"
                },
                "mac": {
                  "title": "MAC Address (AA:BB:CC:DD:EE:FF)",
                  "type": "string"
                }
              }
            },
            "presets": {
              "title": "Enabled Preset Modes (shown as switches in climate card)",
              "type": "object",
              "properties": {
                "sleep": { "title": "Sleep Mode", "type": "boolean", "default": true },
                "health": { "title": "Health / Ionizer", "type": "boolean", "default": true },
                "eco": { "title": "Eco / Mildew Prevention", "type": "boolean", "default": true },
                "clean": { "title": "Self Clean", "type": "boolean", "default": true }
              }
            },
            "showComfWind": {
              "title": "Show Comfortable Wind Switch",
              "type": "boolean",
              "default": true
            },
            "showDisplay": {
              "title": "Show Display Switch",
              "type": "boolean",
              "default": true
            },
            "pollInterval": {
              "title": "Poll Interval (seconds)",
              "type": "integer",
              "default": 30,
              "minimum": 5,
              "maximum": 300
            },
            "tempStep": {
              "title": "Temperature Step",
              "type": "number",
              "default": 0.5,
              "oneOf": [
                { "title": "0.5 °C", "enum": [0.5] },
                { "title": "1 °C", "enum": [1] }
              ]
            }
          }
        }
      }
    }
  }
}
